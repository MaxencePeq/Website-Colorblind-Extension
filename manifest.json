{
  "manifest_version": 3,
  "name": "WebSite for Colorblind",
  "version": "1.1",
  "description": "Here, you can change the color of links, texts and background ;)",
  "icons": {},
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/favicon16.ico"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }],
  "permissions": ["activeTab"]
}
